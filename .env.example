# Copie para .env e preencha

GEMINI_API_KEY=
# Admin opcional (alertas legados se GERENTE não estiver definido)
ADMIN_CHAT_ID=
# Responsável por alertas de intervenção, nova venda e transbordo (WhatsApp ID: 55 + DDD + número, ex. Thais +55 18 98115-7143 → 5518981157143@c.us)
GERENTE_PROCESSO_CHAT_ID=

# Mercado Pago — Access Token (produção ou teste)
MP_ACCESS_TOKEN=

# Mercado Pago — Public Key (produção ou teste)
MP_PUBLIC_KEY=

# URL pública do túnel/servidor, sem barra final (ex: https://xxxx.ngrok-free.app)
WEBHOOK_BASE_URL=https://SEU_TUNEL_AQUI.ngrok-free.app

# Assinatura secreta dos Webhooks (Mercado Pago → Suas integrações)
MP_WEBHOOK_SECRET=

# Opcional — túnel público para o painel expor o webhook do Mercado Pago (npm ngrok)
# NGROK_AUTHTOKEN=

# CORS do painel espelhado (opcional; padrão inclui atualhub com e sem www)
# ORION_CORS_ORIGINS=https://atualhub.com.br,https://www.atualhub.com.br

# Sincronizar api-link.json na Hostinger após subir o ngrok (sync-link.js)
# Opção A — POST para um PHP no site (ver scripts/hostinger-sync-api-link.example.php)
# ORION_SYNC_LINK_URL=https://atualhub.com.br/painel/sync-api-link.php
# ORION_SYNC_LINK_SECRET=
# Opção B — FTP (ex.: Hostinger). Caminho remoto completo do arquivo, ex.: /domains/.../public_html/painel/api-link.json
# ORION_FTP_HOST=ftp.hostinger.com
# ORION_FTP_USER=
# ORION_FTP_PASSWORD=
# ORION_FTP_REMOTE_PATH=
# ORION_FTP_SECURE=1
# ORION_FTP_PORT=21
# API local do ngrok (padrão http://127.0.0.1:4040/api/tunnels)
# ORION_NGROK_API_URL=

# Se o ngrok embutido (npm) falhar mas você usa `ngrok http 3000` no terminal, o index.js
# tenta ler a URL em http://127.0.0.1:4040/api/tunnels automaticamente.

# Opcional
# PORT=3000
# Envia presença "digitando..." antes de responder (pode marcar conversa como lida no app do contato)
# WHATSAPP_SEND_TYPING=0
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# GEMINI_MAX_RETRIES=4
# GEMINI_RETRY_BASE_MS=3000
# Ativa fallback temporário automático quando houver sequência de 503 (alta demanda)
# GEMINI_DEGRADE_TRIGGER_503=2
# GEMINI_DEGRADE_WINDOW_MS=600000
