# Copie para .env e preencha

GEMINI_API_KEY=
ADMIN_CHAT_ID=

# Mercado Pago — Access Token (produção ou teste)
MP_ACCESS_TOKEN=

# Mercado Pago — Public Key (produção ou teste)
MP_PUBLIC_KEY=

# URL pública do túnel/servidor, sem barra final (ex: https://xxxx.ngrok-free.app)
WEBHOOK_BASE_URL=https://SEU_TUNEL_AQUI.ngrok-free.app

# Assinatura secreta dos Webhooks (Mercado Pago → Suas integrações)
MP_WEBHOOK_SECRET=

# Opcional
# PORT=3000
# GEMINI_MODEL=gemini-2.5-flash
